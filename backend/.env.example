# Backend environment variables (set these in Render → Environment)
# PORT is provided automatically by Render — do not hardcode it there.
PORT=5000
MONGO_URI=your-mongodb-atlas-connection-string
JWT_SECRET=your-long-random-secret
# Your deployed frontend URL (Vercel). Used to lock down CORS. Leave unset to allow all origins.
CLIENT_URL=https://your-app.vercel.app
